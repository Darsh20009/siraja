[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && PATH=\"/home/runner/workspace/node_modules/.bin:$PATH\" nest start"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "console"
