modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "5000"
API_PREFIX = "api/v1"
CORS_ORIGINS = "*"
NODE_ENV = "development"
JWT_ACCESS_EXPIRES_IN = "15m"
JWT_REFRESH_EXPIRES_IN = "30d"
LOG_LEVEL = "debug"
MONGODB_DB_NAME = "siraja"
THROTTLE_LIMIT = "100"
THROTTLE_TTL = "60"
EMAIL_FROM = "noreply@siraja.website"
EMAIL_FROM_NAME = "Siraja"
EMAIL_HOST = "server222.web-hosting.com"
EMAIL_PORT = "465"
EMAIL_SECURE = "true"
EMAIL_USER = "noreply@siraja.website"
STORAGE_DRIVER = "s3"
STORAGE_REGION = "auto"
SUPPORT_EMAIL = "support@siraja.website"

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && PATH=\"/home/runner/workspace/node_modules/.bin:$PATH\" nest start"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "console"
