# ==============================
# Siraja Backend - Environment Configuration
# ==============================

# --- Application ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
APP_URL=http://localhost:3000

# --- Database (MongoDB Atlas) ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/siraja?retryWrites=true&w=majority
MONGODB_DB_NAME=siraja

# --- Multi-Tenancy ---
# Strategy: path-based tenant resolution, e.g. siraja.website/:tenantSlug
TENANCY_STRATEGY=path
DEFAULT_TENANT_SLUG=platform

# --- Auth / JWT ---
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# --- OAuth Providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/apple/callback

# NOTE: Phone is an identity field only (login by phone+password) — no
# SMS OTP/verification/reset is implemented, per Phase 4 scope. All
# verification and account recovery is Email-only (see /auth/verify-email,
# /auth/password/forgot, /auth/password/reset above).

# --- Rate Limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# --- Logging ---
LOG_LEVEL=debug
